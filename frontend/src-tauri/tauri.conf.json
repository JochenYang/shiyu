{
  "package": {
    "productName": "时语字幕助手",
    "version": "1.1.0"
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": ".*"
      },
      "fs": {
        "readFile": true,
        "writeFile": true,
        "scope": ["**"]
      },
      "dialog": {
        "save": true,
        "open": true
      },
      "protocol": {
        "asset": true,
        "assetScope": ["**"]
      }
    },
    "bundle": {
      "active": true,
      "category": "Productivity",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.shiyu.subtitle",
      "longDescription": "时语 Shiyu - AI-powered local subtitle generator using SenseVoice",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [
        "resources/backend"
      ],
      "shortDescription": "时语 - 本地 AI 字幕助手",
      "targets": ["nsis", "dmg"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "nsis": {
          "installMode": "currentUser"
        }
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "时语字幕助手",
        "width": 1200,
        "center": true,
        "minWidth": 1000,
        "minHeight": 650,
        "fileDropEnabled": true
      }
    ]
  }
}